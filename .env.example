# Copy this file to .env and update values for your machine.
# Keep .env out of git.

DJANGO_SECRET_KEY=django-insecure-change-me-for-local-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Local SQLite database path, relative to final_project/ unless absolute.
# Each developer can choose their own file name, for example db.rafael.sqlite3.
DJANGO_SQLITE_PATH=db.sqlite3
